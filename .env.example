# Ollama Configuration
OLLAMA_MODEL=qwen3.5
OLLAMA_BASE_URL=http://localhost:11434

# GitLab Configuration (choose GitLab OR GitHub)
GITLAB_TOKEN=your_gitlab_access_token
GITLAB_URL=https://gitlab.com  # or your self-hosted GitLab URL
GITLAB_WEBHOOK_SECRET=your_webhook_secret_here

# GitHub Configuration (alternative to GitLab)
GITHUB_TOKEN=your_github_access_token
GITHUB_WEBHOOK_SECRET=your_webhook_secret_here

# Platform Selection
PLATFORM=github  # or "gitlab"

# Agent Configuration
AGENT_NAME=MR-Reviewer-Bot
MAX_FILES_TO_REVIEW=10
MAX_DIFF_LINES=500

# API Configuration
API_HOST=0.0.0.0
API_PORT=9012
